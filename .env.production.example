# ---------- Backend ----------
NODE_ENV=production
PORT=3000

# IMPORTANT: replace with a strong random value
JWT_SECRET=replace_with_strong_secret

# CORS: public frontend URL(s)
CORS_ORIGINS=http://localhost:3001

# This value is overridden by docker-compose for container networking,
# but keep it for local/non-docker runs.
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/pr_po_db

# Optional mail/env values can be added below if your app uses them.
